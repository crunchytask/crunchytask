# Copy to .env and adjust for local development (optional).
# The C++ CLI and library read TASKQUEUE_REDIS_URI at runtime.
# The Python client also honors TASKQUEUE_TASKQ_BIN when taskq is not on PATH.

# Redis connection URI used by taskq and the Python client.
TASKQUEUE_REDIS_URI=tcp://127.0.0.1:6379

# Path to the taskq binary for clients/python (default: search PATH for "taskq").
# TASKQUEUE_TASKQ_BIN=/home/you/.local/bin/taskq
